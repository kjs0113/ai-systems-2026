{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Task Unit Artifact with Dependencies",
  "type": "object",
  "properties": {
    "id": { "type": "string", "pattern": "^TASK-[0-9]{3}$" },
    "title": { "type": "string" },
    "status": { "enum": ["pending", "in-progress", "done", "failed"] },
    "parent_req": { "type": "string" },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tier": { "type": "integer", "minimum": 0 },
    "files_affected": {
      "type": "array",
      "items": { "type": "string" }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["id", "title", "status", "dependencies", "tier"]
}
