{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CoderOutput",
  "type": "object",
  "required": [
    "task_id",
    "changes",
    "test_command",
    "status"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^task-[0-9]{4}$"
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "file",
          "action",
          "description"
        ],
        "properties": {
          "file": {
            "type": "string"
          },
          "action": {
            "type": "string",
            "enum": [
              "create",
              "modify",
              "delete"
            ]
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "test_command": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "complete",
        "partial",
        "blocked"
      ]
    },
    "blocker": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
